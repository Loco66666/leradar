  },
  "devDependencies": {
    "@types/node": "^22.15.17",
    "eslint": "^9.26.0",
    "prettier": "^3.5.3",
    "prisma": "^6.7.0",
    "typescript": "^5.8.3"
  },
  "dependencies": {
    "@prisma/client": "^6.7.0",
    "dotenv": "^16.5.0",
    "zod": "^3.24.4"
  }
}
